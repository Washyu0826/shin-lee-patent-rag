# === Patent RAG Chatbot v3 ===

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=patent_chunks

# Ollama
OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b-instruct

# Embedding + Reranker
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
ENABLE_RERANK=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3
MIN_RERANK_SCORE=0.05

# OCR
OCR_LANGUAGE=chi_tra+eng
CHUNK_MAX_CHARS=800

# PostgreSQL
DATABASE_URL=postgresql://patent:change-me@localhost:5432/patent_rag
POSTGRES_PASSWORD=change-me

# Auth
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
JWT_SECRET=change-me-to-a-long-random-string

# API
RATE_LIMIT_PER_MINUTE=30
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
PATENT_LIST_LIMIT=1000
COMPARE_SCROLL_LIMIT=300

# Webhook alerts
WEBHOOK_URL=

# Auto-scan folder (optional)
AUTO_SCAN_DIR=./data/patents
AUTO_SCAN_INTERVAL=60
